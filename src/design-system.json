{
  "name": "Travel Check-in App Design System",
  "version": "1.1.0",
  "description": "Design tokens and variables extracted from Figma design for consistent UI implementation",
  
  "colors": {
    "primary": {
      "blue": "#2b7fff",
      "lightBlue": "#51a2ff",
      "purple": "#ad46ff",
      "pink": "#f6339a",
      "gold": "#fdc700",
      "goldDark": "#f0b100",
      "activeTab": "#155dfc"
    },
    "gradient": {
      "primary": "linear-gradient(115deg, #51a2ff 0%, #ad46ff 50%, #f6339a 100%)",
      "button": "linear-gradient(90deg, #2b7fff 0%, #ad46ff 100%)",
      "icon": "linear-gradient(90deg, #2b7fff 0%, #ad46ff 100%)",
      "gold": "linear-gradient(90deg, #fdc700 0%, #f0b100 100%)",
      "blue": "linear-gradient(90deg, #51a2ff 0%, #2b7fff 100%)",
      "mapBackground": "linear-gradient(117deg, #dbeafe 0%, #f3e8ff 50%, #fce7f3 100%)",
      "pageBackground": "linear-gradient(117deg, #eff6ff 0%, #faf5ff 100%)"
    },
    "background": {
      "card": "rgba(255, 255, 255, 0.95)",
      "cardTranslucent": "rgba(255, 255, 255, 0.5)",
      "header": "rgba(255, 255, 255, 0.9)",
      "mapHint": "rgba(255, 255, 255, 0.8)",
      "input": "#f3f3f5",
      "tab": "#ececf0",
      "tabActive": "#ffffff",
      "tabBar": "#ffffff",
      "overlay": "rgba(0, 0, 0, 0.2)",
      "blur1": "rgba(255, 255, 255, 0.2)",
      "blur2": "rgba(255, 255, 255, 0.15)",
      "blur3": "rgba(255, 255, 255, 0.1)"
    },
    "text": {
      "primary": "#1e2939",
      "secondary": "#4a5565",
      "muted": "#6a7282",
      "placeholder": "#717182",
      "dark": "#0a0a0a",
      "link": "#2b7fff",
      "white": "#ffffff",
      "province": "#01579b",
      "provinceVisited": "#0277bd",
      "capital": "#d32f2f"
    },
    "border": {
      "light": "#e5e7eb",
      "input": "rgba(0, 0, 0, 0)",
      "button": "rgba(0, 0, 0, 0.1)",
      "mapCard": "#ffffff"
    }
  },
  
  "typography": {
    "fontFamily": {
      "primary": "'Inter', 'Noto Sans SC', 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "bold": 700
    },
    "lineHeight": {
      "tight": "14px",
      "normal": "20px",
      "relaxed": "24px",
      "loose": "36px"
    }
  },
  
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "40px"
  },
  
  "borderRadius": {
    "sm": "8px",
    "md": "14px",
    "lg": "22px",
    "xl": "28px",
    "full": "9999px"
  },
  
  "shadows": {
    "card": "0px 25px 50px rgba(0, 0, 0, 0.25)",
    "soft": "0px 10px 30px rgba(31, 41, 55, 0.08)",
    "header": "0px 4px 6px rgba(0, 0, 0, 0.1)",
    "mapCard": "0px 20px 25px rgba(0, 0, 0, 0.1)",
    "tabBar": "0px -10px 15px rgba(0, 0, 0, 0.1)"
  },
  
  "blur": {
    "default": "24px"
  },
  
  "layout": {
    "cardWidth": "360px",
    "cardPadding": "32px",
    "inputHeight": "36px",
    "buttonHeight": "44px",
    "tabHeight": "36px",
    "tabBarHeight": "64px",
    "statCardHeight": "68px",
    "iconSize": {
      "xs": "16px",
      "sm": "20px",
      "md": "24px",
      "lg": "32px",
      "xl": "48px"
    }
  },
  
  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "220ms",
      "slow": "300ms"
    },
    "easing": {
      "default": "ease",
      "smooth": "cubic-bezier(0.22, 1, 0.36, 1)"
    }
  },
  
